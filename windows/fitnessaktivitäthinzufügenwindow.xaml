<Window x:Class="Pantry_To_Plate.windows.fitnessaktivitäthinzufügenwindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local="clr-namespace:Pantry_To_Plate.windows" mc:Ignorable="d" Title="Fitnessaktivität hinzufügen" Height="534" Width="1037" MinHeight="500" MinWidth="820" WindowStartupLocation="CenterOwner" Background="#FFF7F7FB">

    <Window.Resources>
        <DropShadowEffect x:Key="SoftShadow" BlurRadius="22" ShadowDepth="4" Opacity="0.14"/>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#FF232331"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#FF5E5E72"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="#FF252535"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFE3E3EC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="14">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#FF2B2B3A"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFE8E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF648C58"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF567B4C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF486A40"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FFCACAD5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="#FF648C58"/>
            <Setter Property="Background" Value="#FFE8EFE5"/>
            <Setter Property="BorderBrush" Value="#FFD7E4D1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="26" Background="#FFE8EFE5" Padding="26" Margin="0,0,511,20" Effect="{StaticResource SoftShadow}">
            <StackPanel>
                <TextBlock Text="Fitnessaktivität hinzufügen" FontSize="30" FontWeight="Bold" Foreground="#FF202030"/>
            </StackPanel>
        </Border>

        <Grid Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="0.9*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="24" Padding="24" Margin="0,128,50,0" Effect="{StaticResource SoftShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="313*"/>
                        <ColumnDefinition Width="90*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Aktivität auswählen" FontSize="21" FontWeight="Bold" Grid.ColumnSpan="2" Margin="0,0,0,39" Grid.RowSpan="2"/>
                    <Label Grid.Row="1" Content="Wähle eine Fitnessaktivität aus der Liste:" Margin="0,10,0,10" Grid.ColumnSpan="2"/>
                    <ListBox DisplayMemberPath="Name" Grid.Row="2" Name="ListBoxAktivitaeten" d:ItemsSource="{d:SampleData ItemCount=5}" SelectionChanged="ListBoxAktivitaeten_SelectionChanged" Grid.ColumnSpan="2"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="24" Padding="24" Effect="{StaticResource SoftShadow}" Margin="0,198,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Dauer eintragen" FontSize="21" FontWeight="Bold"/>
                    <Label Grid.Row="1" Content="Dauer in Minuten:" Margin="0,22,0,8"/>
                    <TextBox Grid.Row="2" Name="TxtBoxDauerMinuten" Height="52" TextWrapping="Wrap" Text="0"/>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                        <Button Content="Schließen" Width="130" Height="48" Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" Click="Schliessen_Click"/>
                        <Button Content="Speichern und schließen" Width="190" Height="48" Style="{StaticResource PrimaryButtonStyle}" Click="SpeichernUndSchliessen_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
            <Border Grid.Column="1" Background="White" CornerRadius="24" Padding="24" Margin="0,-10,16,290" Effect="{StaticResource SoftShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="313*"/>
                        <ColumnDefinition Width="90*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Bisherige Aktivitäten" FontSize="21" FontWeight="Bold" Grid.ColumnSpan="2" Margin="0,0,0,39" Grid.RowSpan="2"/>
                    <ListBox DisplayMemberPath="Name" Grid.Row="1" x:Name="ListBoxAktivitaeten1" d:ItemsSource="{d:SampleData ItemCount=5}" SelectionChanged="ListBoxAktivitaeten_SelectionChanged" Grid.ColumnSpan="2" Margin="0,10,0,-14" Grid.RowSpan="2"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
