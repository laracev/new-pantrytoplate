<Window x:Class="Pantry_To_Plate.windows.EinstellungenWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local="clr-namespace:Pantry_To_Plate.windows" mc:Ignorable="d" Title="EinstellungenWindow" Height="856" Width="1245" MinHeight="580" MinWidth="920" WindowStartupLocation="CenterOwner" Background="#FFF7F7FA">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#EB477B"/>
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#FFFFF4F8"/>
        <SolidColorBrush x:Key="AccentBorderBrush" Color="#FFFFC8D7"/>
        <SolidColorBrush x:Key="TextDarkBrush" Color="#24242A"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#777783"/>
        <SolidColorBrush x:Key="GreenBrush" Color="#648C58"/>
        <SolidColorBrush x:Key="GreenSoftBrush" Color="#FFE8EFE5"/>
        <DropShadowEffect x:Key="SoftShadow" Color="#22000000" BlurRadius="22" ShadowDepth="4" Opacity="0.18"/>
        <DropShadowEffect x:Key="ButtonShadow" Color="#22000000" BlurRadius="14" ShadowDepth="3" Opacity="0.20"/>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFE4E4EC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="14">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFE4E4EC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#EB477B"/>
            <Setter Property="Background" Value="#FFFFF4F8"/>
            <Setter Property="BorderBrush" Value="#FFFFC8D7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Effect" Value="{StaticResource ButtonShadow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FFFFE8F0"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#EB477B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FFFFDDE9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#EB477B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#EB477B"/>
        </Style>

        <Style x:Key="GreenButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#FFE8EFE5"/>
            <Setter Property="Foreground" Value="#648C58"/>
            <Setter Property="BorderBrush" Value="#FFD7E4D1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="30" Background="#FFFFEEF4" BorderBrush="#FFFFC8D7" BorderThickness="1" Padding="28" Margin="0,0,0,22" Effect="{StaticResource SoftShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Einstellungen" FontSize="32" FontWeight="Bold" Foreground="#24242A"/>
                    <TextBlock Text="Passe dein Tagesziel, deine Aktivität und deine persönlichen Werte an." FontSize="15" Foreground="#777783" Margin="0,8,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" Width="78" Height="78" CornerRadius="24" Background="White" BorderBrush="#FFFFC8D7" BorderThickness="1">
                    <TextBlock Text="⚙" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*"/>
                <ColumnDefinition Width="1.35*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="28" Padding="24" Margin="0,0,20,0" Effect="{StaticResource SoftShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Schnellaktionen" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Text="Speichern, schließen oder deine eingetragenen Mahlzeiten prüfen." FontSize="14" Foreground="#777783" TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,24,0,0">
                        <Button Background="GhostWhite" Content="eingetragene Mahlzeiten&#xD;&#xA;anzeigen" Height="54" Width="260" HorizontalAlignment="Stretch" Click="Button_Click_2"/>
                        <Button Background="GhostWhite" Content="Einstellungen Schließen" Height="54" Width="260" HorizontalAlignment="Stretch" Margin="0,12,0,0" Click="Button_Click"/>
                        <Button Background="GhostWhite" Content="Werte Speichern und &#xD;&#xA;Einstellungen schließen" Height="62" Width="260" HorizontalAlignment="Stretch" Margin="0,12,0,0" Click="Button_Click_3" Style="{StaticResource PrimaryButtonStyle}" Foreground="Red"/>
                    </StackPanel>

                    <Border Grid.Row="2" Background="#FFFFF4F8" BorderBrush="#FFFFC8D7" BorderThickness="1" CornerRadius="24" Padding="20" Margin="0,28,0,0">
                        <StackPanel>
                            <TextBlock Text="Tageskalorienziel" FontSize="20" FontWeight="Bold" Foreground="#EB477B"/>
                            <Label Content="Tageskalorienziel:" Margin="0,14,0,6"/>
                            <TextBox Name="ziel" Text="0" TextWrapping="Wrap" TextChanged="TextBox_TextChanged_3"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="3" Background="#FFE8EFE5" BorderBrush="#FFD7E4D1" BorderThickness="1" CornerRadius="24" Padding="18" Margin="0,22,0,0" VerticalAlignment="Bottom">
                        <TextBlock Text="Tipp: Speichere deine Werte, damit dein Dashboard direkt mit deinem aktuellen Ziel arbeiten kann." FontSize="13" Foreground="#4F6F46" TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="28" Padding="24" Effect="{StaticResource SoftShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Persönliche Daten" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Text="Diese Angaben helfen bei der Berechnung deines empfohlenen Tagesziels." FontSize="14" Foreground="#777783" TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,22,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Label Content="Diätziel:"/>
                            <ComboBox Name="diätzielCombo" SelectionChanged="ComboBox_SelectionChanged">
                                <Label Name="zunehmenComboans" Content="Gewicht Zunehmen"/>
                                <Label Name="haltenComboans" Content="Gewicht Halten"/>
                                <Label Name="abnehmenComboans" Content="Gewicht Abnehmen"/>
                            </ComboBox>

                            <Label Content="Alltagstätigkeit:" Margin="0,16,0,0"/>
                            <ComboBox Name="AlltagCombo" SelectionChanged="ComboBox_SelectionChanged_1">
                                <Label Name="LPal" Content="nur liegend"/>
                                <Label Name="MLPal" Content="Meist Liegend"/>
                                <Label Name="NSPal" Content="Nur Sitzend (z.B. Büro)"/>
                                <Label Name="ÜSPal" Content="Überwiegend Sitzend (z.B. Schüler;Lehrer"/>
                                <Label Name="VSGPal" Content="Überwiegend Stehend/Gehend (z.B. Frieseur)"/>
                                <Label Name="VKPal" Content="Vorwiegend Körperlich (z.B. Bauarbeiter, Sportler)"/>
                            </ComboBox>

                            <Label Content="Geschlecht:" Margin="0,16,0,0"/>
                            <ComboBox Name="Geschlechtcombo" SelectionChanged="ComboBox_SelectionChanged_2">
                                <Label Name="malec" Content="Männlich"/>
                                <Label Name="femc" Content="Weiblich"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Label Content="Alter:"/>
                            <TextBox Name="ageans" Text="1.2" TextWrapping="Wrap" TextChanged="TextBox_TextChanged_2"/>

                            <Label Content="Gewicht eingeben:&#xA;(Kg)" Margin="0,16,0,0"/>
                            <TextBox Name="Gewichteingabe" Text="0" TextWrapping="Wrap" TextChanged="TextBox_TextChanged_1"/>

                            <Label Content="Größe eingeben: &#xA;(cm)" Margin="0,16,0,0"/>
                            <TextBox Name="größeeingabe" Text="0" TextWrapping="Wrap" TextChanged="TextBox_TextChanged"/>
                        </StackPanel>
                    </Grid>

                    <Button Grid.Row="1" Background="GhostWhite" Content="Empfehlung für das &#xA;Tagesziel Berechnen&#xD;&#xA;und Einfügen" Click="Button_Click_1" Style="{StaticResource GreenButtonStyle}" Margin="0,376,0,18"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
