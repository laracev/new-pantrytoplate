<UserControl x:Class="Pantry_To_Plate.UserControls.UserControl1"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Pantry_To_Plate.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Canvas x:Name="RootCanvas" Width="400" Height="23" ClipToBounds="True">
            <Border Width="400" Height="23" CornerRadius="11" Background="#FFE8EFE5"/>
            <Rectangle x:Name="ProgressRect" Width="0" Height="23" Fill="#648C58"/>
            <Border Width="400" Height="23" CornerRadius="11" BorderBrush="#FFC8D7" BorderThickness="1"/>
        </Canvas>

    </Grid>
</UserControl>
