<Window x:Class="Pantry_To_Plate.windows.AnimationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Pantry_To_Plate.windows"
        mc:Ignorable="d"
        Title="AnimationWindow" Height="450" Width="800" Loaded="Window_Loaded" Opacity="0">
    <Grid>
        <Image x:Name="Logo"
               Source="../Screenshot 2026-05-07 134630.png"
               Width="200"
               Height="200"
               RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <ScaleTransform x:Name="LogoScale" ScaleX="0.7" ScaleY="0.7"/>
                </Image.RenderTransform>
            </Image>
        </Grid>
</Window>
